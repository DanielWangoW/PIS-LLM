# Streamlit Community Cloud — Secrets Template
# In Streamlit Cloud dashboard: Settings → Secrets → paste content below
# (Remove the .example suffix; this file is for reference only)

[api_keys]
DASHSCOPE_API_KEY  = "sk-your-dashscope-key"
DEEPSEEK_API_KEY   = "sk-your-deepseek-key"
ZHIPU_API_KEY      = "your-zhipu-key"
MOONSHOT_API_KEY   = "sk-your-moonshot-key"
